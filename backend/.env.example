# Database
POSTGRES_USER=planpilot
POSTGRES_PASSWORD=planpilot
POSTGRES_DB=planpilot
DATABASE_URL=postgresql+asyncpg://planpilot:planpilot@localhost:5432/planpilot

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_generate_a_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Groq (https://console.groq.com)
GROQ_API_KEY=gsk_...

# App
APP_ENV=development
APP_NAME=PlanPilot
CORS_ORIGINS=http://localhost:3000
